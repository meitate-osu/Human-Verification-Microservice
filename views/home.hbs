<div class="container">
    <button type="submit" class="btn" onclick="openPopup()">Upload Image</button>
    <div class="overlay" id="overlay"></div>
    <div class="popup" id="popup">
        <h2>Upload Your Image</h2>
        <p>Select an image from your computer</p>
        <form class='uploader' method="post" enctype="multipart/form-data" action="/upload">
            <input type="file" class='file' name="file" onchange="readURL(this)" onclick="openCertainty()">
            <img id="verify" class="verify" src=""/>
            <p id="certainty" class="certainty">Is this the correct image??</p>
            <input id="submit" type="submit" class='submit' value="Submit">
        </form>
        <button id="humanity" type="humanity" class="humanity">I am not a bot</button>
        <p>Your uploaded images may be viewed for research purposes</p>
        <button class="close" types="button" onclick="closePopup()">Close</button>
    </div>
</div>

