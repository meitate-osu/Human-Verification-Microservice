<div class='myimages' id="myimages">
</div>

<div class="divfoot">
</div>



<script>

    let popup = document.getElementById("popup")

    let overlay = document.getElementById("overlay")

    let popup2 = document.getElementById("popup2")

    let overlay2 = document.getElementById("overlay2")

    let submit = document.getElementById("submit")

    let humanity = document.getElementById("humanity")

    let certainty = document.getElementById("certainty")

    function openCertainty() {
        certainty.classList.add("open-certainty")
    }

    function openPopup(){
        popup.classList.add("open-popup");
        overlay.classList.add("open-overlay");
        humanity.classList.add("open-humanity")
    }

    function openPopup2(){
        popup2.classList.add("open-popup2");
        overlay2.classList.add("open-overlay2");
    }

        function closePopup2(){
        popup2.classList.remove("open-popup2");
        overlay2.classList.remove("open-overlay2");
    }

    function closePopup(){
        popup.classList.remove("open-popup");
        overlay.classList.remove("open-overlay");
        submit.classList.remove("open-submit")
        humanity.classList.remove("open-humanity")
        certainty.classList.remove("open-certainty")
    }
    
    overlay.onclick = function () {
        popup.classList.remove("open-popup");
        overlay.classList.remove("open-overlay");
        submit.classList.remove("open-submit")
        humanity.classList.remove("open-humanity")
        certainty.classList.remove("open-certainty")
    };

    overlay2.onclick = function () {
        popup2.classList.remove("open-popup2");
        overlay2.classList.remove("open-overlay2");
    };
</script>

<script>
        fetch('/api/images')
            .then(response => response.json())
            .then(images => {
                const gallery = document.getElementById('myimages');
                images.forEach(imageName => {
                    const img = document.createElement('img');
                    img.src = `/images/${imageName}`;
                    gallery.appendChild(img);
                });
            });
</script>

<script>
    //preview function based on Diego Fortes' response to https://stackoverflow.com/questions/58773912/how-can-i-display-a-photo-chosen-through-a-html-input-in-a-div
    function readURL(input) {
            if (input.files && input.files[0]) {
                const reader = new FileReader();

                reader.onload = function (e) {
                  document.querySelector('#verify').setAttribute('src',e.target.result )

                };

                reader.readAsDataURL(input.files[0]);
            }
        }
</script>

<script>
    document.getElementById('humanity').addEventListener('click', async () => {
        const write = await fetch('/write-to-file', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ textData: "verify" })
        });
        const result = await write.text();
        alert('verification successful');
        try {
            // Request the file data from the Node.js endpoint
            const read = await fetch('read-file');
            const text = await read.text();

            if (text == 'verified') {
                submit.classList.add("open-submit")
                humanity.classList.remove("open-humanity")
            }
            

        } catch (error) {
            console.error('Fetch error:', error);
        }
    });
</script>